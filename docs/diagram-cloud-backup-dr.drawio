        <!-- Title -->
        <mxCell id="title-erd" value="&lt;b&gt;Entity Relationship Diagram (ERD) — Conceptual Model&lt;/b&gt;&lt;br&gt;Cloud Backup &amp; Disaster Recovery System" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=16;" vertex="1" parent="1">
