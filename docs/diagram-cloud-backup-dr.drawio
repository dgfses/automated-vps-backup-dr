        <!-- ======== ENTITIES ======== -->

        <!-- E: Server -->
        <mxCell id="erd-server" value="&lt;b style=&quot;border-bottom:1px solid #333;padding-bottom:4px;display:block;margin-bottom:6px;&quot;&gt;SERVER&lt;/b&gt;&lt;u&gt;server_id&lt;/u&gt;&lt;br&gt;hostname&lt;br&gt;ip_address&lt;br&gt;os_version&lt;br&gt;disk_capacity&lt;br&gt;disk_usage" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=11;align=left;spacingLeft=10;spacingRight=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="80" y="90" width="160" height="155" as="geometry"/>
        </mxCell>

        <!-- E: Database -->
        <mxCell id="erd-db" value="&lt;b style=&quot;border-bottom:1px solid #333;padding-bottom:4px;display:block;margin-bottom:6px;&quot;&gt;DATABASE&lt;/b&gt;&lt;u&gt;db_name&lt;/u&gt;&lt;br&gt;db_type (MySQL/MariaDB)&lt;br&gt;host&lt;br&gt;port&lt;br&gt;charset" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=11;align=left;spacingLeft=10;spacingRight=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="80" y="330" width="190" height="140" as="geometry"/>
        </mxCell>

        <!-- E: WebDirectory -->
        <mxCell id="erd-webdir" value="&lt;b style=&quot;border-bottom:1px solid #333;padding-bottom:4px;display:block;margin-bottom:6px;&quot;&gt;WEB_DIRECTORY&lt;/b&gt;&lt;u&gt;dir_path&lt;/u&gt;&lt;br&gt;owner&lt;br&gt;group&lt;br&gt;permissions&lt;br&gt;total_size" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=11;align=left;spacingLeft=10;spacingRight=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="80" y="550" width="170" height="140" as="geometry"/>
        </mxCell>

        <!-- E: BackupJob -->
        <mxCell id="erd-job" value="&lt;b style=&quot;border-bottom:1px solid #333;padding-bottom:4px;display:block;margin-bottom:6px;&quot;&gt;BACKUP_JOB&lt;/b&gt;&lt;u&gt;job_id&lt;/u&gt;&lt;br&gt;triggered_by&lt;br&gt;start_time&lt;br&gt;end_time&lt;br&gt;duration_seconds&lt;br&gt;status (SUCCESS/FAILED)&lt;br&gt;error_message&lt;br&gt;retention_applied" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=11;align=left;spacingLeft=10;spacingRight=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="440" y="80" width="210" height="195" as="geometry"/>
        </mxCell>

        <!-- E: BackupFile -->
        <mxCell id="erd-file" value="&lt;b style=&quot;border-bottom:1px solid #333;padding-bottom:4px;display:block;margin-bottom:6px;&quot;&gt;BACKUP_FILE&lt;/b&gt;&lt;u&gt;filename&lt;/u&gt;&lt;br&gt;format (.tar.gz)&lt;br&gt;file_size&lt;br&gt;created_at&lt;br&gt;local_path&lt;br&gt;remote_path&lt;br&gt;is_uploaded&lt;br&gt;expires_at" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=11;align=left;spacingLeft=10;spacingRight=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="440" y="370" width="180" height="195" as="geometry"/>
        </mxCell>

        <!-- E: CloudRemote -->
        <mxCell id="erd-cloud" value="&lt;b style=&quot;border-bottom:1px solid #333;padding-bottom:4px;display:block;margin-bottom:6px;&quot;&gt;CLOUD_REMOTE&lt;/b&gt;&lt;u&gt;remote_name&lt;/u&gt;&lt;br&gt;provider (GDrive/S3/R2)&lt;br&gt;target_folder&lt;br&gt;auth_type (OAuth/Key)&lt;br&gt;max_transfers" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=11;align=left;spacingLeft=10;spacingRight=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="810" y="370" width="200" height="150" as="geometry"/>
        </mxCell>

        <!-- E: Notification -->
        <mxCell id="erd-notif" value="&lt;b style=&quot;border-bottom:1px solid #333;padding-bottom:4px;display:block;margin-bottom:6px;&quot;&gt;NOTIFICATION&lt;/b&gt;&lt;u&gt;notif_id&lt;/u&gt;&lt;br&gt;channel (Telegram)&lt;br&gt;bot_token&lt;br&gt;chat_id&lt;br&gt;timestamp&lt;br&gt;status_code&lt;br&gt;message_content" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontSize=11;align=left;spacingLeft=10;spacingRight=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="810" y="90" width="190" height="175" as="geometry"/>
        </mxCell>

        <!-- E: CronSchedule -->
        <mxCell id="erd-cron" value="&lt;b style=&quot;border-bottom:1px solid #333;padding-bottom:4px;display:block;margin-bottom:6px;&quot;&gt;CRON_SCHEDULE&lt;/b&gt;&lt;u&gt;schedule_id&lt;/u&gt;&lt;br&gt;cron_expression&lt;br&gt;script_path&lt;br&gt;lock_file_path&lt;br&gt;log_file_path&lt;br&gt;is_active" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;fontSize=11;align=left;spacingLeft=10;spacingRight=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="440" y="640" width="180" height="160" as="geometry"/>
        </mxCell>

        <!-- E: RetentionPolicy -->
        <mxCell id="erd-retention" value="&lt;b style=&quot;border-bottom:1px solid #333;padding-bottom:4px;display:block;margin-bottom:6px;&quot;&gt;RETENTION_POLICY&lt;/b&gt;&lt;u&gt;policy_id&lt;/u&gt;&lt;br&gt;max_age_days&lt;br&gt;scope (local/remote/both)&lt;br&gt;last_executed&lt;br&gt;files_deleted_count" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;fontSize=11;align=left;spacingLeft=10;spacingRight=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="810" y="590" width="210" height="145" as="geometry"/>
        </mxCell>

        <!-- E: Credentials -->
        <mxCell id="erd-cred" value="&lt;b style=&quot;border-bottom:1px solid #333;padding-bottom:4px;display:block;margin-bottom:6px;&quot;&gt;CREDENTIALS&lt;/b&gt;&lt;u&gt;cred_id&lt;/u&gt;&lt;br&gt;file_path (.my.cnf)&lt;br&gt;permissions (600)&lt;br&gt;db_user&lt;br&gt;db_host&lt;br&gt;owner (root)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e6d0de;strokeColor=#996185;strokeWidth=2;fontSize=11;align=left;spacingLeft=10;spacingRight=10;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="80" y="750" width="180" height="155" as="geometry"/>
        </mxCell>

