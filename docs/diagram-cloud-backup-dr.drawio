  <!-- ============================================================ -->
  <!-- PAGE 4: ERD — Entity Relationship Diagram                    -->
  <!-- ============================================================ -->
  <diagram name="ERD - Entity Relationship" id="erd">
    <mxGraphModel dx="1422" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="900" math="0" shadow="0">
